{
  "baseUrl": "http://localhost:8083/api",
  "timeout": 10000,
  "headers": {
    "accept": "*/*",
    "Content-Type": "application/json"
  },
  "endpoints": {
    "wallet": {
      "walletinfo": "/wallet/info",
      "bindAlipay": "/wallet/bind-alipay",
      "setpaymentpwd": "/wallet/security-password",
      "withdraw": "/wallet/withdraw",
      "availablebalance": "/wallet/available-balance",
      "validatepwd": "/wallet/validate-security-password?password=",
      "transactionrecord": "/wallet/transactions"
    },
    "task": {
      "missionhall": "/tasks/hall"
    },
    "bank": {
      "getbankcardslist": "/bank-cards/",
      "addbankcard": "/bank-cards/",
      "setdefaultbankcard": "/bank-cards/{cardId}/default",
      "getdefaultbankcard": "/bank-cards/default"
    }
  },
  "mockMode": false,
  "retryCount": 3,
  "retryDelay": 1000
}